# secret-scan allowlist (honored by ~/.config/git/hooks/pre-push via
# scripts/ci/secret_scan.py). One path glob per line; '#' starts a comment.
#
# Generated golden fixtures are deterministic generator output (synthetic test
# data produced by scripts/golden.sh), not hand-authored source. They embed Go
# struct field names and config keys that pattern-match as credentials but hold
# no real values. The specs (catalog/specs/) and generator source stay scanned;
# only the generated expected tree is skipped.
testdata/golden/expected/**
